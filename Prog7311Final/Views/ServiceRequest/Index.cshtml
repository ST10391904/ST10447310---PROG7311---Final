@model IEnumerable<Prog7311Final.Models.ServiceRequest>

<h2>Service Requests</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Contract</th>
            <th>Description</th>
            <th>Cost</th>
            <th>Status</th>
            <th>SLA</th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.ServiceRequestId</td>
            <td>@item.ContractId</td>
            <td>@item.Description</td>
            <td>@item.Cost</td>
            <td>@item.Status</td>
            <td>
                <a asp-action="RequestSLA"
                   asp-route-id="@item.ServiceRequestId"
                   class="btn btn-info btn-sm">
                    Request SLA
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>