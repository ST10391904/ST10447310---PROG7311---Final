@model IEnumerable<Prog7311Final.Models.Contract>

<h2>Contracts</h2>

<p>
    <a asp-action="Create" class="btn btn-success">New Contract</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Amount</th>
            <th>Currency</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model)
    {
        <tr>
            <td>@item.ContractName</td>
            <td>@item.Amount</td>
            <td>@item.Currency</td>
            <td>@item.Status</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ContractId">Edit</a> |
                <a asp-action="Delete" asp-route-id="@item.ContractId">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>